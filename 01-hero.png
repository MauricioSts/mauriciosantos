/* ===== Mauricio Santos · Portfólio 2.0 — design system ===== */
:root{
  --bg:#0A0E1A; --bg2:#0D1320; --panel:#101725; --panel2:#0c1220;
  --line:#1b2840; --line2:#27374f;
  --green:#10B981; --green2:#00E6A0; --glow:rgba(16,185,129,.30);
  --txt:#F4F6FB; --mut:#9AA4B8; --mut2:#65718a;
  --mono:'JetBrains Mono',ui-monospace,monospace; --disp:'Space Grotesk',sans-serif;
  --ease:cubic-bezier(.22,.61,.36,1);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--bg); color:var(--txt); font-family:var(--mono);
  -webkit-font-smoothing:antialiased; overflow-x:hidden; line-height:1.6;
}
@media (pointer:fine){ body{cursor:none} }
img{max-width:100%;display:block}
::selection{background:var(--green);color:#04150e}

/* scroll progress */
.progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:90;
  background:linear-gradient(90deg,var(--green),var(--green2));box-shadow:0 0 12px var(--glow)}

/* custom cursor */
.cur,.cur-ring{position:fixed;top:0;left:0;z-index:99;pointer-events:none;border-radius:50%;
  transform:translate(-50%,-50%);will-change:transform}
.cur{width:6px;height:6px;background:var(--green2)}
.cur-ring{width:34px;height:34px;border:1.5px solid rgba(16,185,129,.55);
  transition:width .22s var(--ease),height .22s var(--ease),background .22s var(--ease),border-color .22s var(--ease)}
.cur-ring.hot{width:56px;height:56px;background:rgba(16,185,129,.12);border-color:var(--green2)}
@media (pointer:coarse){ .cur,.cur-ring{display:none} }

/* starfield */
.stars{position:fixed;inset:0;z-index:0;pointer-events:none}
.stars i{position:absolute;border-radius:50%;background:#fff;animation:tw 4s var(--ease) infinite}
@keyframes tw{0%,100%{opacity:.15}50%{opacity:.7}}
@media (prefers-reduced-motion:reduce){ .stars i{animation:none} }

/* layout */
.shell{position:relative;z-index:2}
.wrap{max-width:1180px;margin:0 auto;padding:0 28px}
section{position:relative}
.eyebrow{display:inline-flex;align-items:center;gap:12px;color:var(--green2);font-size:12px;
  letter-spacing:.34em;text-transform:uppercase;margin-bottom:22px}
.eyebrow::before{content:"";width:42px;height:1px;background:var(--green)}
h1,h2,h3{font-family:var(--disp);letter-spacing:-.02em;line-height:1.02;font-weight:700}

/* ===== header ===== */
.hd{position:fixed;top:0;left:0;right:0;z-index:80;transition:background .3s,border-color .3s,backdrop-filter .3s;
  border-bottom:1px solid transparent}
.hd.scrolled{background:rgba(10,14,26,.7);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.hd-in{max-width:1180px;margin:0 auto;padding:16px 28px;display:flex;align-items:center;justify-content:space-between;gap:16px}
.logo{display:flex;align-items:center;gap:11px;font-family:var(--disp);font-weight:700;font-size:15px}
.logo .badge{width:32px;height:32px;border-radius:9px;display:grid;place-items:center;font-size:12px;color:#04150e;font-weight:700;
  background:linear-gradient(135deg,var(--green),var(--green2));box-shadow:0 0 18px var(--glow)}
.nav{position:relative;display:flex;align-items:center;gap:4px;background:rgba(13,19,32,.6);border:1px solid var(--line);
  padding:5px;border-radius:14px}
.nav button{position:relative;font-family:var(--mono);font-size:13px;color:var(--mut);background:none;border:none;
  padding:8px 15px;border-radius:9px;cursor:none;z-index:1;transition:color .25s}
.nav button.on{color:#04150e;font-weight:700}
.nav .pill{position:absolute;top:5px;bottom:5px;border-radius:9px;background:linear-gradient(135deg,var(--green),var(--green2));
  box-shadow:0 0 16px var(--glow);transition:left .35s var(--ease),width .35s var(--ease);z-index:0}
.lang{font-family:var(--mono);font-size:12px;color:var(--mut);border:1px solid var(--line2);background:var(--panel2);
  padding:9px 12px;border-radius:9px;cursor:none;transition:.25s}
.lang:hover{color:var(--green2);border-color:var(--green)}
@media(max-width:820px){ .nav{display:none} }

/* ===== hero ===== */
.hero{padding:160px 0 70px;display:grid;grid-template-columns:1.15fr .85fr;gap:56px;align-items:center}
@media(max-width:900px){ .hero{grid-template-columns:1fr;padding-top:130px} }
.hero h1{font-size:clamp(48px,9vw,108px);text-transform:uppercase}
.hero h1 .l2{color:transparent;-webkit-text-stroke:1.6px var(--txt);display:block}
.roleline{display:inline-flex;align-items:center;gap:14px;margin:22px 0 26px;font-size:15px;color:var(--mut)}
.rolebox{display:inline-flex;align-items:center;border:1px solid var(--green);color:var(--green2);
  padding:7px 16px;border-radius:10px;min-width:170px;box-shadow:0 0 18px var(--glow) inset;
  font-family:var(--mono);position:relative}
.rolebox::after{content:"";width:9px;height:18px;background:var(--green2);margin-left:3px;animation:caret 1s steps(1) infinite}
@keyframes caret{50%{opacity:0}}
.bio{color:var(--mut);max-width:54ch;font-size:14.5px}
.bio + .bio{margin-top:15px}
.bio b{color:var(--txt)}
.social{display:flex;gap:10px;margin-top:28px}
.social a{width:46px;height:46px;border-radius:12px;display:grid;place-items:center;color:var(--mut);
  background:var(--panel2);border:1px solid var(--line);cursor:none;transition:.25s var(--ease)}
.social a:hover{color:var(--green2);border-color:var(--green);transform:translateY(-3px);box-shadow:0 10px 24px -12px var(--glow)}
.social svg{width:19px;height:19px}

/* hero photo */
.photo{position:relative;border-radius:22px;padding:10px;border:1px solid var(--line);background:linear-gradient(160deg,var(--panel),var(--panel2));
  box-shadow:0 30px 80px -40px var(--glow);transform-style:preserve-3d;will-change:transform}
.photo .frame{position:relative;border-radius:15px;aspect-ratio:4/5;overflow:hidden;
  background:radial-gradient(120% 90% at 30% 10%,#1a2742,#0b1220);display:grid;place-items:center}
.photo .ph{text-align:center;color:var(--mut2);font-size:12px;letter-spacing:.05em}
.photo .ph .mk{width:74px;height:74px;border-radius:18px;margin:0 auto 14px;display:grid;place-items:center;font-family:var(--disp);
  font-weight:700;font-size:26px;color:#04150e;background:linear-gradient(135deg,var(--green),var(--green2));box-shadow:0 0 26px var(--glow)}
.photo .chip{position:absolute;top:16px;right:16px;width:48px;height:48px;border-radius:13px;display:grid;place-items:center;
  font-family:var(--disp);font-weight:700;color:#04150e;background:linear-gradient(135deg,var(--green),var(--green2));box-shadow:0 0 20px var(--glow)}
.scan{position:absolute;left:10px;right:10px;height:2px;top:10px;background:linear-gradient(90deg,transparent,var(--green2),transparent);
  opacity:.7;animation:scan 3.4s var(--ease) infinite}
@keyframes scan{0%,100%{top:12px}50%{top:calc(100% - 14px)}}
@media (prefers-reduced-motion:reduce){ .scan{animation:none} }

/* stats */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;border-top:1px solid var(--line);margin-top:60px;padding-top:34px}
.stat .n{font-family:var(--disp);font-weight:700;font-size:clamp(34px,5vw,52px);color:var(--green2)}
.stat .k{color:var(--mut2);font-size:12px;letter-spacing:.18em;text-transform:uppercase;margin-top:4px}

/* marquee */
.marq{border-top:1px solid var(--line);border-bottom:1px solid var(--line);overflow:hidden;margin-top:64px;padding:18px 0;
  background:var(--panel2)}
.marq .row{display:flex;gap:48px;width:max-content;animation:scrollx 26s linear infinite}
.marq:hover .row{animation-play-state:paused}
.marq span{font-family:var(--disp);font-weight:700;font-size:22px;color:var(--mut);white-space:nowrap;display:inline-flex;align-items:center;gap:48px}
.marq span::after{content:"◆";color:var(--green2);font-size:11px}
@keyframes scrollx{to{transform:translateX(-50%)}}
@media (prefers-reduced-motion:reduce){ .marq .row{animation:none} }

/* section headers */
.shead{padding:96px 0 8px}
.shead h2{font-size:clamp(30px,5vw,52px);display:flex;align-items:baseline;gap:16px;flex-wrap:wrap}
.shead h2 .idx{font-family:var(--mono);font-size:14px;color:var(--green2);font-weight:700;border:1px solid var(--green);
  border-radius:8px;padding:5px 10px;align-self:center}
.shead .sub{color:var(--mut2);margin-top:12px;font-size:14px}

/* projects */
.projs{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin-top:42px}
@media(max-width:760px){ .projs{grid-template-columns:1fr} }
.card{position:relative;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:var(--panel2);cursor:none;
  transition:transform .4s var(--ease),border-color .35s,box-shadow .4s}
.card:hover{transform:translateY(-6px);border-color:var(--green);box-shadow:0 26px 60px -34px var(--glow)}
.card .thumb{position:relative;aspect-ratio:16/10;overflow:hidden;display:grid;place-items:center}
.card .thumb .gloss{position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(10,14,26,.85))}
.card .num{position:absolute;left:16px;top:16px;z-index:3;font-family:var(--mono);font-weight:700;color:#04150e;
  background:linear-gradient(135deg,var(--green),var(--green2));padding:5px 10px;border-radius:8px;font-size:13px;box-shadow:0 0 16px var(--glow)}
.card .open{position:absolute;right:14px;top:14px;z-index:3;width:38px;height:38px;border-radius:11px;display:grid;place-items:center;
  background:rgba(10,14,26,.6);border:1px solid var(--line2);color:var(--txt);opacity:0;transform:translateY(-6px) rotate(-12deg);transition:.35s var(--ease)}
.card:hover .open{opacity:1;transform:none;color:var(--green2);border-color:var(--green)}
.card .body{padding:22px 22px 24px}
.card h3{font-size:22px}
.card .desc{color:var(--mut);font-size:13.5px;margin-top:9px;min-height:40px}
.tags{display:flex;gap:7px;flex-wrap:wrap;margin-top:15px}
.tag{font-size:11.5px;color:var(--mut);border:1px solid var(--line2);background:var(--panel);padding:4px 10px;border-radius:7px}
.more{margin-top:18px;display:inline-flex;align-items:center;gap:8px;color:var(--green2);font-size:13px;font-weight:700}
.more svg{width:15px;height:15px;transition:transform .3s var(--ease)}
.card:hover .more svg{transform:translateX(5px)}

/* mini mockup placeholders inside thumb */
.mock{position:absolute;inset:0;padding:14px;display:flex;flex-direction:column;gap:7px}
.mock .bar{height:7px;border-radius:4px;background:rgba(255,255,255,.08)}
.mock .blk{flex:1;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06)}
.mock .dots{display:flex;gap:5px}.mock .dots i{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.18)}

/* timeline */
.tl{margin-top:42px;position:relative;padding-left:34px}
.tl::before{content:"";position:absolute;left:9px;top:6px;bottom:6px;width:2px;background:var(--line)}
.tl .fill{position:absolute;left:9px;top:6px;width:2px;background:linear-gradient(var(--green),var(--green2));box-shadow:0 0 12px var(--glow);height:0;transition:height .1s linear}
.tlitem{position:relative;padding:0 0 38px}
.tlitem .dot{position:absolute;left:-33px;top:4px;width:20px;height:20px;border-radius:50%;background:var(--bg);
  border:2px solid var(--green);display:grid;place-items:center}
.tlitem .dot::after{content:"";width:8px;height:8px;border-radius:50%;background:var(--green2);box-shadow:0 0 10px var(--glow)}
.tlitem .when{font-size:12px;color:var(--green2);letter-spacing:.05em}
.tlitem h3{font-size:20px;margin:5px 0 4px}
.tlitem .org{color:var(--mut);font-size:13px}
.tlitem p{color:var(--mut2);font-size:13.5px;margin-top:9px;max-width:60ch}

/* devtools */
.tabs{position:relative;display:flex;gap:6px;flex-wrap:wrap;margin-top:34px;background:var(--panel2);border:1px solid var(--line);
  padding:6px;border-radius:14px;width:max-content;max-width:100%}
.tabs button{position:relative;font-family:var(--mono);font-size:13px;color:var(--mut);background:none;border:none;
  padding:10px 18px;border-radius:9px;cursor:none;transition:color .25s}
.tabs button.on{color:#04150e;font-weight:700}
.tabs .tpill{position:absolute;top:6px;bottom:6px;border-radius:9px;background:linear-gradient(135deg,var(--green),var(--green2));
  box-shadow:0 0 16px var(--glow);transition:left .35s var(--ease),width .35s var(--ease)}
.stackgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:14px;margin-top:26px}
.stk{display:flex;flex-direction:column;align-items:center;gap:12px;padding:24px 14px;border-radius:14px;
  background:var(--panel2);border:1px solid var(--line);transition:.3s var(--ease)}
.stk:hover{border-color:var(--green);transform:translateY(-4px);box-shadow:0 18px 40px -24px var(--glow)}
@keyframes pop{from{opacity:0;transform:translateY(14px) scale(.96)}to{opacity:1;transform:none}}
.stk .ic{width:46px;height:46px;border-radius:12px;display:grid;place-items:center;font-family:var(--disp);font-weight:700;
  font-size:16px;color:var(--green2);background:var(--panel);border:1px solid var(--line2)}
.stk .nm{font-size:12.5px;color:var(--mut)}

/* contato */
.contact{text-align:center;padding:30px 0 10px}
.contact h2{font-size:clamp(34px,6vw,64px)}
.contact p{color:var(--mut);margin-top:14px}
.mailbtn{display:inline-flex;align-items:center;gap:13px;margin-top:34px;font-family:var(--mono);font-weight:700;font-size:16px;
  color:#04150e;background:linear-gradient(135deg,var(--green),var(--green2));padding:18px 30px;border-radius:14px;
  border:none;cursor:none;box-shadow:0 14px 40px -14px var(--glow);transition:.3s var(--ease)}
.mailbtn:hover{transform:translateY(-3px);box-shadow:0 20px 50px -16px var(--glow)}
.mailbtn .mi{width:26px;height:26px;border-radius:7px;background:#fff;display:grid;place-items:center;color:#04150e}

footer{text-align:center;color:var(--mut2);font-size:12.5px;padding:80px 0 56px;margin-top:40px;border-top:1px solid var(--line)}
footer b{color:var(--mut)}

/* ===== reveal ===== */
.rv.pre{opacity:0}
.rv.in{animation:revealIn .7s var(--ease)}
@keyframes revealIn{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@media (prefers-reduced-motion:reduce){ .rv{opacity:1}.rv.in{animation:none} }

/* ===== project detail (segunda aba) ===== */
.detail{position:fixed;inset:0;z-index:95;background:var(--bg);overflow-y:auto;
  animation:slideUp .5s cubic-bezier(.22,.61,.36,1)}
@keyframes slideUp{from{transform:translateY(48px);opacity:0}to{transform:none;opacity:1}}
.detail .dwrap{max-width:1100px;margin:0 auto;padding:90px 28px 80px}
.dbar{position:fixed;top:0;left:0;right:0;z-index:2;background:rgba(10,14,26,.72);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--line)}
.dbar-in{max-width:1100px;margin:0 auto;padding:16px 28px;display:flex;align-items:center;justify-content:space-between}
.back{display:inline-flex;align-items:center;gap:9px;color:var(--mut);background:none;border:none;font-family:var(--mono);
  font-size:14px;cursor:none;transition:.25s}
.back:hover{color:var(--green2)}
.dtitlebar{font-family:var(--mono);color:var(--green2);font-size:14px;letter-spacing:.1em}
.dgrid{display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:start;margin-top:18px}
@media(max-width:880px){ .dgrid{grid-template-columns:1fr;gap:30px} }
.dshot{border:1px solid var(--line);border-radius:18px;overflow:hidden;background:var(--panel2);position:sticky;top:100px}
.dshot .thumb{aspect-ratio:16/11}
.dnum{font-family:var(--mono);font-weight:700;color:#04150e;background:linear-gradient(135deg,var(--green),var(--green2));
  padding:6px 12px;border-radius:9px;font-size:15px;display:inline-block;box-shadow:0 0 18px var(--glow)}
.detail h1{font-size:clamp(38px,6vw,68px);margin:18px 0 16px}
.dtags{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:30px}
.dtag{font-size:13px;color:var(--green2);border:1px solid var(--green);background:rgba(16,185,129,.06);padding:6px 13px;border-radius:8px}
.block{border:1px solid var(--line);border-radius:16px;padding:24px;background:var(--panel2);margin-bottom:18px}
.block .lbl{display:flex;align-items:center;gap:9px;font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:700;margin-bottom:13px}
.block.prob .lbl{color:#ff6b6b}.block.sol .lbl{color:var(--green2)}
.block .lbl .led{width:9px;height:9px;border-radius:50%}
.block.prob .led{background:#ff6b6b;box-shadow:0 0 10px #ff6b6b88}
.block.sol .led{background:var(--green2);box-shadow:0 0 10px var(--glow)}
.block p{color:var(--mut);font-size:14.5px}
.access{display:inline-flex;align-items:center;gap:10px;margin-top:8px;font-family:var(--mono);font-weight:700;color:#04150e;
  background:linear-gradient(135deg,var(--green),var(--green2));padding:15px 26px;border-radius:13px;border:none;cursor:none;
  box-shadow:0 14px 40px -16px var(--glow);transition:.3s var(--ease);text-decoration:none}
.access:hover{transform:translateY(-3px)}
.dnavpair{display:flex;justify-content:space-between;gap:14px;margin-top:46px;border-top:1px solid var(--line);padding-top:26px}
.dnavpair button{background:none;border:none;color:var(--mut);font-family:var(--mono);font-size:13px;cursor:none;text-align:left;transition:.25s}
.dnavpair button:hover{color:var(--green2)}
.dnavpair .nx{text-align:right}
.dnavpair .nx h4,.dnavpair button h4{font-family:var(--disp);font-size:19px;color:var(--txt);margin-top:4px}
.dnavpair button:hover h4{color:var(--green2)}

/* preloader */
.pre{position:fixed;inset:0;z-index:200;background:var(--bg);display:grid;place-items:center;transition:opacity .6s,visibility .6s}
.pre.done{opacity:0;visibility:hidden}
.pre .cnt{font-family:var(--disp);font-weight:700;font-size:clamp(60px,14vw,150px);color:var(--txt)}
.pre .cnt b{color:var(--green2)}
.pre .lbl{font-family:var(--mono);color:var(--mut2);font-size:12px;letter-spacing:.4em;text-transform:uppercase;text-align:center;margin-top:6px}
