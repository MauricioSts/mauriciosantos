function Timeline(){
  const ref=useRef(null), fill=useRef(null);
  useEffect(()=>{
    const onScroll=()=>{ if(!ref.current||!fill.current) return;
      const r=ref.current.getBoundingClientRect();
      const passed=Math.max(0, innerHeight*0.55 - r.top);
      fill.current.style.height=Math.min(r.height,passed)+"px"; };
    addEventListener("scroll",onScroll,{passive:true}); onScroll();
    return ()=>removeEventListener("scroll",onScroll);
  },[]);
  return <section id="experiencias">
    <div className="wrap">
      <Reveal className="shead"><h2><span className="idx">03</span> Experiências</h2><div className="sub">Trajetória profissional e acadêmica.</div></Reveal>
      <div className="tl" ref={ref}>
        <div className="fill" ref={fill}></div>
        {EXPERIENCES.map((e,i)=>(
          <Reveal className={"tlitem d"+(i+1)} key={i}>
            <div className="dot"></div>
            <div className="when">{e.when}</div>
            <h3>{e.role}</h3>
            <div className="org">{e.org}</div>
            <p>{e.text}</p>
          </Reveal>
        ))}
      </div>
    </div>
  </section>;
}

/* leaf so DevTools section header keeps reveal across tab clicks */
function StackTabs(){
  const keys=Object.keys(STACKS); const [tab,setTab]=useState(0);
  const tref=useRef(null), tp=useRef(null);
  const measure=()=>{ const b=tref.current?.querySelectorAll("button"); if(!b) return;
    const el=b[tab]; if(el&&tp.current&&el.offsetWidth){ tp.current.style.left=el.offsetLeft+"px"; tp.current.style.width=el.offsetWidth+"px"; } };
  useLayoutEffect(()=>{ measure(); },[tab]);
  useEffect(()=>{ const r=()=>requestAnimationFrame(measure); document.fonts?.ready.then(r); addEventListener("resize",r);
    return ()=>removeEventListener("resize",r); },[]);
  return <React.Fragment>
    <div className="tabs" ref={tref}>
      <span className="tpill" ref={tp}></span>
      {keys.map((k,i)=><button key={k} className={i===tab?"on":""} onClick={()=>setTab(i)}>{k}</button>)}
    </div>
    <div className="stackgrid">
      {STACKS[keys[tab]].map(([nm,ic],i)=>(
        <div className="stk" key={nm}>
          <div className="ic">{ic}</div><div className="nm">{nm}</div>
        </div>
      ))}
    </div>
  </React.Fragment>;
}

